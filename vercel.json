{
    "redirects": [
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "www.ciclodehabitos.com"
                }
            ],
            "destination": "https://ciclodehabitos.com/$1",
            "permanent": true
        },
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "header",
                    "key": "x-forwarded-proto",
                    "value": "http"
                }
            ],
            "destination": "https://ciclodehabitos.com/$1",
            "permanent": true
        }
    ]
}